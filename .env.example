# Required — get your key from your WDGoWars profile at https://wdgwars.pl
WDGWARS_API_KEY=your_64_char_key_here

# URL to your ultra feeder's aircraft.json (default works for sdr-enthusiasts image)
# WDGWARS_ULTRA_FEEDER_URL=http://ultrafeeder/data/aircraft.json

# WDGoWars upload endpoint
# WDGWARS_UPLOAD_URL=https://wdgwars.pl/api/upload/

# Seconds between polls (default: 30)
# WDGWARS_POLL_INTERVAL=30

# Aircraft records per upload request (default: 500)
# WDGWARS_BATCH_SIZE=500

# Log verbosity: DEBUG, INFO, WARNING (default: INFO)
# WDGWARS_LOG_LEVEL=INFO

# Location spoofing — all four must be set or spoofing is disabled
# WDGWARS_STATION_LAT=52.2297
# WDGWARS_STATION_LON=21.0122
# WDGWARS_FAKE_LAT=48.8566
# WDGWARS_FAKE_LON=2.3522
